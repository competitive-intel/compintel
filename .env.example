# Shared by API and Worker
DATABASE_URL=postgresql://compintel:compintel@localhost:5432/compintel
REDIS_URL=redis://localhost:6379

# API
API_HOST=127.0.0.1
API_PORT=3000
NODE_ENV=development

# Tencent Cloud SES (API only; leave empty to disable verification email)
TENCENT_SES_SECRET_ID=
TENCENT_SES_SECRET_KEY=

# Worker
JUDGE_URL=http://localhost:5050
JUDGE_AUTH_TOKEN=

# Database seed (administrator creation is skipped when ADMIN_PASSWORD is empty)
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=平台管理员
ADMIN_PASSWORD=change-me-123

# Web (defaults to /api when omitted)
VITE_API_BASE_URL=/api

# Optional go-judge integration test; uncomment JUDGE_E2E_URL to enable it
# JUDGE_E2E_URL=http://localhost:5050
# JUDGE_E2E_AUTH_TOKEN=
