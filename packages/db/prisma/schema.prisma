generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum PlayerKind {
  USER
  PLATFORM
}

enum PlayerLanguage {
  CPP
}

enum EvaluationStatus {
  QUEUED
  COMPILING
  RUNNING
  FINISHED
}

enum EvaluationVerdict {
  ACCEPTED
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  OUTPUT_LIMIT_EXCEEDED
  DANGEROUS_SYSCALL
  INVALID_MOVE
  INTERNAL_ERROR
}

enum MatchStatus {
  QUEUED
  RUNNING
  FINISHED
}

enum MatchOutcome {
  WIN
  LOSS
  DRAW
  ERROR
}

enum UserRole {
  USER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  displayName    String
  passwordHash   String
  role           UserRole       @default(USER)
  approvalStatus ApprovalStatus @default(PENDING)
  reviewedAt     DateTime?
  reviewedById   String?
  reviewedBy     User?          @relation("UserReviews", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedUsers  User[]         @relation("UserReviews")
  sessions       Session[]
  players        Player[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([approvalStatus, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  summary         String
  description     String
  rulesMarkdown   String
  rulesVersion    String
  moveCpuLimitMs  Int      @default(100)
  totalCpuLimitMs Int      @default(5000)
  memoryLimitMiB  Int      @default(256)
  isPublished     Boolean  @default(false)
  players         Player[]
  matches         Match[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished, createdAt])
}

model Player {
  id        String          @id @default(cuid())
  gameId    String
  game      Game            @relation(fields: [gameId], references: [id], onDelete: Restrict)
  ownerId   String?
  owner     User?           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  kind      PlayerKind
  name      String
  isActive  Boolean         @default(true)
  weight    Int             @default(1)
  versions  PlayerVersion[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([gameId, ownerId, name])
  @@index([gameId, kind])
}

model PlayerVersion {
  id                  String             @id @default(cuid())
  playerId            String
  player              Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  version             Int
  language            PlayerLanguage
  sourceCode          String
  sourceSha256        String
  score               Int?
  evaluations         Evaluation[]       @relation("EvaluationSubject")
  opponentEvaluations Evaluation[]       @relation("EvaluationOpponent")
  matchParticipants   MatchParticipant[]
  createdAt           DateTime           @default(now())

  @@unique([playerId, version])
}

model Evaluation {
  id                    String             @id @default(cuid())
  playerVersionId       String
  playerVersion         PlayerVersion      @relation("EvaluationSubject", fields: [playerVersionId], references: [id], onDelete: Cascade)
  opponentVersionId     String
  opponentVersion       PlayerVersion      @relation("EvaluationOpponent", fields: [opponentVersionId], references: [id], onDelete: Restrict)
  opponentWeight        Int                @default(1)
  won                   Boolean            @default(false)
  status                EvaluationStatus   @default(QUEUED)
  verdict               EvaluationVerdict?
  attempts              Int                @default(0)
  compileStatus         String?
  compileLog            String?
  opponentCompileStatus String?
  opponentCompileLog    String?
  runStatus             String?
  opponentRunStatus     String?
  stdout                String?
  stderr                String?
  opponentStderr        String?
  cpuTimeNs             BigInt?
  wallTimeNs            BigInt?
  memoryBytes           BigInt?
  opponentCpuTimeNs     BigInt?
  opponentWallTimeNs    BigInt?
  opponentMemoryBytes   BigInt?
  errorMessage          String?
  replay                Json?
  createdAt             DateTime           @default(now())
  startedAt             DateTime?
  finishedAt            DateTime?

  @@index([playerVersionId, createdAt])
  @@index([opponentVersionId])
  @@index([status, createdAt])
}

model Match {
  id           String             @id @default(cuid())
  gameId       String
  game         Game               @relation(fields: [gameId], references: [id], onDelete: Restrict)
  status       MatchStatus        @default(QUEUED)
  participants MatchParticipant[]
  replayKey    String?
  createdAt    DateTime           @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  @@index([gameId, createdAt])
}

model MatchParticipant {
  id              String        @id @default(cuid())
  matchId         String
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerVersionId String
  playerVersion   PlayerVersion @relation(fields: [playerVersionId], references: [id], onDelete: Restrict)
  seat            Int
  outcome         MatchOutcome?
  detail          Json?

  @@unique([matchId, seat])
  @@unique([matchId, playerVersionId])
}
